# MEC Automation Tool — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is listed in .gitignore and will NOT be committed to git.
# Never share your API key or commit it to version control.

# ── Required ───────────────────────────────────────────────────────────────

# Your Anthropic API key.
# Get one at: https://console.anthropic.com/api-keys
# Starts with: sk-ant-
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional ───────────────────────────────────────────────────────────────

# Override the default data directory (default: data/)
# MEC_DATA_DIR=data

# Override the default output directory (default: output/)
# MEC_OUTPUT_DIR=output

# Override the default config directory (default: config/)
# MEC_CONFIG_DIR=config

# Set default model (haiku | sonnet | opus). CLI --model flag takes precedence.
# MEC_DEFAULT_MODEL=sonnet

# Set default variance threshold percentage. Client config takes precedence.
# MEC_DEFAULT_THRESHOLD=5.0
